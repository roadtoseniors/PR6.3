<Page x:Class="pr14V2.Pages.ProfilePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ProfilePage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" Padding="40,0" BorderBrush="#2C2C2C" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="← Назад" Click="BackButton_Click" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand"/>
                <TextBlock Text="Профиль" FontSize="24" FontWeight="Bold" Margin="30,0,0,0"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="40,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"></ColumnDefinition>
                <ColumnDefinition Width="30"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Профиль" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Логин" FontSize="14" Foreground="#5C5C5C"/>
                    <TextBlock x:Name="LoginText" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="Дата регистрации" FontSize="14" Foreground="#5C5C5C"/>
                    <TextBlock x:Name="DateText" FontSize="16" Margin="0,0,0,30"/>
                    <Button x:Name="LogoutButton" Content="Выйти из аккаунта" Click="LogoutButton_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="15,10" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Мои билеты" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="600">
                    <ItemsControl x:Name="TicketsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"></ColumnDefinition>
                                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Movie}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Hall}" FontSize="14" Foreground="#5C5C5C" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding Date}" FontSize="14" Foreground="#5C5C5C" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Seat}" FontSize="14" Foreground="#5C5C5C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                            <TextBlock Text="{Binding Price}" FontSize="20" FontWeight="Bold" Foreground="#28A745"/>
                                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
