<Page x:Class="pr14V2.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14V2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>
        <!-- header -->
        <Border Grid.Row="0" BorderBrush="Black" Padding="40,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <!-- лого -->
                <TextBlock Grid.Column="0" Text="КИНОРМАСИК" FontSize="26" FontWeight="Bold" Foreground="#2C2C2C" VerticalAlignment="Center" Margin="0,0,60,0"/>

                <!-- название -->
                <TextBlock Grid.Column="1" TextAlignment="Center"  Padding="20,0" Text="Регистрация/вход" FontSize="20" VerticalAlignment="Center"/>

                <!-- кнопка назад -->
                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1" CornerRadius="10" Height="44">
                    <Button x:Name="BackButton" Background="Transparent" BorderThickness="0" Content="Вернуться назад" FontSize="20" Padding="32,0" Height="44" Click="BackButton_Click"/>
                </Border>
            </Grid>
        </Border>
        <!-- main -->
        <Border Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="Black" Width="400" Height="350">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="LoginButton" Grid.Column="0" FontSize="15" Content="Войти" Width="150" Height="30"  Background="Transparent" BorderBrush="Transparent" Click="LoginButton_Click"/>
                        <Button x:Name="RegisterButton" Grid.Column="1" FontSize="15"  Content="Зарегистрироваться"  Width="150" Height="30"  Background="Transparent" BorderBrush="Transparent"/>
                    </Grid>
                </StackPanel>
                <StackPanel Margin="5,5,5,5" VerticalAlignment="Center" Grid.Row="1">
                    <TextBlock Text="Введите логин" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBox x:Name="RegLoginTextBox" Padding="8,10" Height="38"/>
                    <TextBlock Text="Введите пароль" FontSize="20"  HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="FirstRegPassTextBox" Padding="8,10" Height="38"/>
                    <TextBlock Text="Подтвердите пароль" FontSize="20" HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="SecondRegPassTextBox" Padding="8,10" Height="38"/>
                </StackPanel>
                <Button Grid.Row="1" Width="150" x:Name="RegInputButton" Content="Зарегистрироваться" FontSize="15" Background="Transparent" VerticalAlignment="Bottom" Margin="5,5,5,10" Click="InputButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>

