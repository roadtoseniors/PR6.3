<Page x:Class="pr14V2.Pages.MovieDetailPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="MovieDetailPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" Padding="40,0" BorderBrush="#2C2C2C" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="← Назад" Click="BackButton_Click" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand"/>
                <TextBlock x:Name="MovieTitle" Text="Название фильма" FontSize="24" FontWeight="Bold" Margin="30,0,0,0"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Margin="40,30">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <Border Width="200" Height="300" Background="#E8E8E8" CornerRadius="12">
                    <Image x:Name="MoviePoster" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Margin="30,0,0,0" Width="400">
                    <TextBlock x:Name="MovieRating" Text="★ 0.0" FontSize="20" Foreground="#FFB800" Margin="0,0,0,10"/>
                    <TextBlock x:Name="MovieAge" Text="18+" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock x:Name="MovieDescription" TextWrapping="Wrap" FontSize="14" Foreground="#5C5C5C"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="Выберите сеанс" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="400">
                <ItemsControl x:Name="SessionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="18" FontWeight="Bold">
                                        <Run Text="{Binding SessionTime, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                                        <LineBreak/>
                                        <Run Text="{Binding SessionTime, StringFormat='{}{0:HH:mm}'}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding HallName}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" FontSize="18" FontWeight="Bold" Foreground="#28A745" VerticalAlignment="Center">
                                        <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                        <Run Text=" ₽"/>
                                    </TextBlock>
                                    <Button Grid.Column="3" Content="Выбрать" Click="SelectSession_Click" Tag="{Binding SessionId}" Background="#2C2C2C" Foreground="White" Padding="20,10" FontSize="14" Cursor="Hand" BorderThickness="0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
