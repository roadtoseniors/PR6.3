<Page x:Class="pr14V2.Pages.ForgotPass"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ForgotPass">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="Black" Padding="40,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="КИНОРМАСИК" FontSize="26" FontWeight="Bold" VerticalAlignment="Center"></TextBlock>
                <TextBlock Grid.Column="1" Text="Восстановление пароля" FontSize="20" VerticalAlignment="Center" TextAlignment="Center"></TextBlock>
                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1" CornerRadius="10" Height="44">
                    <Button Content="Вернуться назад" Background="Transparent" BorderThickness="0" Click="BackButton_Click"></Button>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" BorderThickness="1" BorderBrush="Black" Width="400" Height="350">
            <StackPanel Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Введите логин" FontSize="20" HorizontalAlignment="Center"></TextBlock>
                <TextBox x:Name="LoginTextBox" Padding="8,10" Height="38"></TextBox>
                <TextBlock Text="Капча" FontSize="20" HorizontalAlignment="Center"></TextBlock>
                <TextBlock x:Name="CaptchaText" Height="35" FontSize="16" TextAlignment="Center" VerticalAlignment="Center"></TextBlock>
                <TextBox x:Name="CaptchaInput" Padding="8,10" Height="38"></TextBox>
                <Button Content="Проверить" Height="35" Margin="0,10,0,0" Click="CheckButton_Click"></Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
